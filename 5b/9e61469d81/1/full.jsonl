  strings.forEach((str, i) => {\n      text += str;\n      if (i < values.length) text += `$${i + 1}`;\n    });\n    return pg.query(text, values).then((r) => r.rows);\n  };\n}\n  \nbeforeEach(async () => {\n  pglite = new PGlite();\n  db.sql = createPgliteSql(pglite);\n  await pglite.exec(schema);\n  await pglite.query(\"INSERT INTO users (username, password_hash) VALUES ($1, $2)\", [\n    \"testuser\",\n    \"hashed_password_123\",\n  ]);\n});\nafterEach(async () => {\n  await pglite.close();\n});\n","numLines":35,"startLine":1,"totalLines":35}},"sourceToolAssistantUUID":"e14511b1-28d8-4704-b400-c9b56b0c4b41","userType":"external","entrypoint":"cli","cwd":"/home/mohmqat/Work/week-5-project-express","sessionId":"b2fcc734-76f8-4658-8f19-aea41c1d0f01","version":"2.1.101","gitBranch":"week-6-7","slug":"snazzy-prancing-fountain"}
