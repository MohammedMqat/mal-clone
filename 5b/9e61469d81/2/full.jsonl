{\n            return res.status(401).json({ message: \"invalid credentials\" });\n        }\n        // If we get here, login is valid — now we sign a JWT\n    });\n})\n.catch ((err) => {\n    return res.status(500).json({\n        message: \"500 Internal Server Error\"\n    });\n})}","numLines":54,"startLine":1,"totalLines":54}},"sourceToolAssistantUUID":"d08a3acb-dc9a-491e-9a75-2033d2642a15","userType":"external","entrypoint":"cli","cwd":"/home/mohmqat/Work/week-5-project-express","sessionId":"b6041bb7-e5c5-46fe-9602-f99648a1a1bd","version":"2.1.101","gitBranch":"week-6-7","slug":"whimsical-whistling-stearns"}
