{
  "name": "week-5-project-express",
  "version": "1.0.0",
  "description": "",
  "keywords": [],
  "homepage": "https://github.com/MohammedMqat/week-5-project-express#readme",
  "bugs": {
    "url": "https://github.com/MohammedMqat/week-5-project-express/issues"
