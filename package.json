  "license": "ISC",
  "author": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MohammedMqat/week-5-project-express.git"
  },
  "directories": {
    "doc": "docs"
  },
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --env-file=.env --watch src/server.js",
    "start": "node --env-file=.env src/server.js",
    "db:init": "docker exec -i mal-clone-db psql -U postgres < db/init.sql",
    "db:build": "node --env-file=.env db/build.js",
    "db:setup": "npm run db:init && npm run db:build",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "test": "vitest",
    "test:run": "vitest run",
    "prepare": "husky"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "lru-cache": "^11.2.7",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.4.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "supertest": "^7.2.2",
    "vitest": "^4.1.0"
  },
  "lint-staged": {
    "*.js": [
      "oxlint",
      "oxfmt --check"
    ]
  }
}
